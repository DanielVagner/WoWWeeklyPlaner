generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth required tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  sub               String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ─────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  battlenetId String?   @unique
  battletag   String?
  name          String?
  email         String?   @unique
  emailVerified DateTime?            // vyžaduje @next-auth/prisma-adapter
  image         String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  characters  Character[]
}

model Character {
  id          String    @id @default(cuid())
  userId      String
  characterId Int       @unique          // Blizzard character ID
  name        String
  realm       String
  realmSlug   String
  region      String    @default("eu")
  class       String
  spec        String    @default("")
  role        String    @default("dps") // dps | heal | tank
  avgIlvl     Float     @default(0)
  level       Int       @default(80)
  lastSyncedAt DateTime?
  isTracked    Boolean   @default(false)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyStates WeeklyState[]
}

model WeeklyState {
  id             String   @id @default(cuid())
  characterId    String
  weekStart      DateTime // Každé úterý 07:00 UTC (WoW reset)
  mpRunsDone     Int      @default(0)
  mpHighestKey   Int      @default(0)
  mpTopKeys      String   @default("[]") // JSON int[] – sorted desc, used for per-slot vault ilvl
  raidBossesDone Int      @default(0)
  delvesDone     Int      @default(0)
  tasksDone      String   @default("[]") // JSON array – SQLite nemá native array

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, weekStart])
}

model AhSnapshot {
  id         String   @id @default(cuid())
  region     String
  itemId     Int
  price      Int      // v copper
  snapshotAt DateTime @default(now())

  @@index([itemId, region, snapshotAt])
}
